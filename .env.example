# === 必填 ===
TARGET_GROUP_IDS=       # 群号，逗号分隔。加:group发群里，不加发私聊
                        # 例: 123,456:group,789:group
GEMINI_API_KEY=         # Google Gemini API Key

# === 可选（均有默认值，通常不需要改） ===
# ONEBOT_HTTP_URL=http://127.0.0.1:3000   # NapCat HTTP 地址
# BOT_QQ=                                  # 留空自动获取机器人QQ
# LLM_API_KEY=                             # 备用LLM (DeepSeek) API Key
# LLM_BASE_URL=https://api.siliconflow.cn/v1
